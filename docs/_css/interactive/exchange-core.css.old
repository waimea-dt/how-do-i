/**
 * exchange-core.css — Shared styles for two-party exchange visualizers
 *
 * Used by: diffie-hellman, sym-asym, and future exchange-based plugins
 * (e.g., wifi-handshake, digital-signature)
 *
 * Pattern: Alice | Exchange/Arrows | Bob grid layout with:
 *   - Party sections (left/right participants)
 *   - Exchange column (arrows, transmissions)
 *   - Eve/eavesdropper sections (optional)
 *   - Step state management (active, completed, show)
 *   - Responsive breakpoints (600px, 1024px)
 *
 * All plugins use common .exchange-* classes defined here.
 * Plugin-specific styling goes in separate CSS files.
 */

/* ==================== Base Container ==================== */

.markdown-section sym-asym,
.markdown-section diffie-hellman {
    display: block;
    margin: var(--margin-block) 0;
    container-type: inline-size;

    /* Default design tokens (can be overridden by plugins) */
    --exchange-bg:                  var(--color-mono-0);
    --exchange-header-bg:           var(--color-mono-1);
    --exchange-card-bg:             var(--color-mono-1);
    --exchange-border:              var(--color-mono-4);
    --exchange-border-light:        var(--color-mono-2);

    --exchange-text-primary:        var(--color-text);
    --exchange-text-secondary:      var(--color-mono-6);
    --exchange-text-muted:          var(--color-mono-5);

    --exchange-step-bg:             var(--color-mono-1);
    --exchange-step-border:         var(--color-mono-3);
    --exchange-step-active-border:  var(--theme-color);
    --exchange-step-active-bg:      color-mix(in srgb, var(--theme-color), var(--color-mono-min) 75%);
    --exchange-step-complete-bg:    color-mix(in srgb, var(--theme-color), var(--color-mono-min) 90%);

    --exchange-value-bg:            var(--color-mono-0);
    --exchange-value-border:        var(--theme-color-4);
    --exchange-value-var:           var(--theme-color-6);
    --exchange-value-value:         var(--color-text);

    --exchange-eve-bg:              color-mix(in srgb, var(--color-attention), transparent 95%);
    --exchange-eve-border:          color-mix(in srgb, var(--color-attention), transparent 10%);

    --exchange-btn-bg:              var(--color-mono-min);
    --exchange-btn-border:          var(--color-mono-3);
    --exchange-btn-text:            var(--color-text);
    --exchange-btn-hover:           var(--theme-color);
    --exchange-btn-reset-color:     var(--color-attention);

    --exchange-font-mono:           var(--font-family-mono);
    --exchange-gap:                 1rem;
    --exchange-gap-small:           0.5rem;
    --exchange-padding:             1rem;
    --exchange-padding-med:         0.7rem;
    --exchange-padding-small:       0.5rem;
    --exchange-padding-tiny:        0.25rem;
}

/* ==================== Main Wrapper ==================== */

.sa-wrapper,
.dh-wrapper {
    background: var(--sa-bg, var(--dh-bg, var(--color-mono-0)));
    border: 2px solid var(--sa-border, var(--dh-border, var(--color-mono-4)));
    border-radius: var(--border-radius);
    box-shadow: var(--box-shadow);
    overflow: hidden;
}

/* ==================== Header ==================== */

.sa-header,
.dh-header {
    display: flex;
    flex-direction: column;
    gap: var(--sa-gap, var(--dh-gap, 1rem));
    padding: var(--sa-padding, var(--dh-padding, 1rem));
    border-bottom: 2px solid var(--sa-border, var(--dh-border, var(--color-mono-4)));
    background-color: var(--sa-header-bg, var(--dh-header-bg, var(--color-mono-1)));

    @container (min-width: 1024px) {
        flex-direction: row;
        align-items: center;
    }
}

.sa-header-content,
.dh-header-content {
    flex: 1;
}

.sa-title,
.dh-title {
    font-size: 1.25em;
    font-weight: 700;
    color: var(--sa-text-primary, var(--dh-text-primary, var(--color-text)));
    margin-bottom: 0.25rem;
}

.sa-subtitle,
.dh-subtitle {
    font-size: 0.9em;
    color: var(--sa-text-secondary, var(--dh-text-secondary, var(--color-mono-6)));
    line-height: 1.5;
}

/* ==================== Main Grid (Alice | Exchange | Bob) ==================== */

.sa-main-grid,
.dh-main-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sa-gap, var(--dh-gap, 1rem));
    padding: var(--sa-padding, var(--dh-padding, 1rem));
    background: var(--sa-bg, var(--dh-bg, var(--color-mono-0)));

    /* Mobile: vertical stack (sa uses bob/exchange/alice order) */
    grid-template-areas:
        "party-a"
        "exchange"
        "party-b";

    /* Tablet: 2x2 grid */
    @container (min-width: 600px) {
        grid-template-columns: 1fr 1fr;
        grid-template-areas:
            "party-a party-b"
            "exchange exchange";
    }

    /* Desktop: 3-column with exchange in middle */
    @container (min-width: 1024px) {
        grid-template-columns: 1fr auto 1fr;
        grid-template-areas: "party-a exchange party-b";
    }
}

/* Fix grid areas for each plugin's conventions */
.sa-main-grid {
    grid-template-areas:
        "bob"
        "exchange"
        "alice";

    @container (min-width: 600px) {
        grid-template-areas:
            "bob alice"
            "exchange exchange";
    }

    @container (min-width: 1024px) {
        grid-template-areas: "alice exchange bob";
    }
}

.dh-main-grid {
    grid-template-areas:
        "alice"
        "exchange"
        "bob";

    @container (min-width: 600px) {
        grid-template-areas:
            "alice bob"
            "exchange exchange";
    }

    @container (min-width: 1024px) {
        grid-template-areas: "alice exchange bob";
    }
}

/* ==================== Party Sections ==================== */

.sa-party,
.dh-party {
    display: flex;
    flex-direction: column;
    gap: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
}

.sa-party-header,
.dh-party-header {
    text-align: center;
    padding-bottom: var(--sa-padding-small, var(--dh-padding-small, 0.5rem));
    border-bottom: 2px solid var(--sa-border-light, var(--dh-border-light, var(--color-mono-2)));
}

.sa-party-name,
.dh-party-name {
    font-size: 1.2em;
    font-weight: 700;
}

.sa-alice,
.dh-alice {
    grid-area: alice;
}

.sa-bob,
.dh-bob {
    grid-area: bob;
}

/* ==================== Steps ==================== */

.sa-step,
.dh-step {
    background: var(--sa-step-bg, var(--dh-step-bg, var(--color-mono-1)));
    border: 2px solid var(--sa-step-border, var(--dh-step-border, var(--color-mono-3)));
    border-radius: var(--border-radius-med);
    padding: var(--sa-padding-small, var(--dh-padding-small, 0.5rem));
    transition: all 300ms;
    opacity: 1;

    @container (min-width: 769px) {
        padding: var(--sa-padding-med, var(--dh-padding-med, 0.7rem));
    }
}

.sa-step.sa-active,
.dh-step.dh-active {
    opacity: 1;
    background: var(--sa-step-active-bg, var(--dh-step-active-bg));
    border-color: var(--sa-step-active-border, var(--dh-step-active-border));
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--theme-color), transparent 85%);
}

.sa-step.sa-completed,
.dh-step.dh-completed {
    background: var(--sa-step-complete-bg, var(--dh-step-complete-bg));
}

.sa-step-label,
.dh-step-label {
    font-size: 0.75em;
    font-weight: 600;
    color: var(--sa-text-secondary, var(--dh-text-secondary, var(--color-mono-6)));
    margin-bottom: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.sa-step-content,
.dh-step-content {
    display: flex;
    flex-direction: column;
    gap: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
}

/* ==================== Exchange Column ==================== */

.sa-exchange,
.dh-exchange {
    grid-area: exchange;
    display: flex;
    flex-direction: column;
    gap: var(--sa-gap, var(--dh-gap, 1rem));

    @container (min-width: 1024px) {
        min-width: 300px;
        max-width: 350px;
    }
}

.sa-exchange-step,
.dh-exchange-step {
    display: flex;
    flex-direction: column;
    gap: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
}

.sa-exchange-label,
.dh-exchange-label {
    font-size: 0.75em;
    font-weight: 600;
    color: var(--sa-text-secondary, var(--dh-text-secondary, var(--color-mono-6)));
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* ==================== Arrows ==================== */

.sa-arrow,
.dh-arrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--sa-card-bg, var(--dh-card-bg, var(--color-mono-1)));
    border: 2px solid var(--sa-border, var(--dh-border, var(--color-mono-4)));
    border-radius: var(--border-radius-med);
    transition: all 300ms;
}

.sa-arrow.sa-animating,
.dh-arrow.dh-animating {
    animation: exchangeArrowPulse 1.1s ease-in-out;
    border-color: var(--theme-color);
    background: color-mix(in srgb, var(--theme-color), var(--color-mono-min) 85%);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--theme-color), transparent 80%);
}

.sa-arrow-arrow,
.dh-arrow-arrow {
    font-size: 1.5em;
    color: var(--theme-color);
    flex-shrink: 0;
}

.sa-arrow-label,
.dh-arrow-label {
    font-size: 0.7em;
    color: var(--sa-text-muted, var(--dh-text-muted, var(--color-mono-5)));
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
}

.sa-arrow-right,
.dh-arrow-right {
    flex-direction: row;
}

.sa-arrow-left,
.dh-arrow-left {
    flex-direction: row-reverse;
}

/* ==================== Eve Sections ==================== */

.sa-eve-intercept,
.sa-eve-note,
.dh-eve-note {
    background: var(--sa-eve-bg, var(--dh-eve-bg, color-mix(in srgb, var(--color-attention), transparent 95%)));
    border: 2px solid var(--sa-eve-border, var(--dh-eve-border, color-mix(in srgb, var(--color-attention), transparent 10%)));
    border-radius: var(--border-radius-med);
    padding: var(--sa-padding-med, var(--dh-padding-med, 0.7rem));
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: all 400ms ease;
}

.sa-eve-intercept.sa-show,
.sa-eve-note.sa-show,
.dh-eve-note.dh-show {
    opacity: 1;
    max-height: 500px;
    margin-top: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
}

.sa-eve-intercept.sa-highlight,
.sa-eve-note.sa-highlight,
.dh-eve-note.dh-highlight {
    animation: exchangeEveHighlight 1.5s ease-in-out;
}

.sa-eve-icon,
.dh-eve-icon {
    font-size: 1.1em;
    font-weight: 700;
    margin-bottom: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
    color: var(--sa-accent-eve, var(--dh-accent-eve, var(--color-attention)));
}

.sa-eve-text,
.dh-eve-text {
    font-size: 0.9em;
    line-height: 1.6;
    margin-bottom: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
    color: var(--sa-text-primary, var(--dh-text-primary, var(--color-text)));
}

.sa-eve-text:last-child,
.dh-eve-text:last-child {
    margin-bottom: 0;
}

.sa-eve-warning,
.sa-eve-problem,
.dh-eve-problem {
    font-size: 0.85em;
    font-weight: 600;
    padding: var(--sa-padding-small, var(--dh-padding-small, 0.5rem));
    margin-top: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
    background: color-mix(in srgb, var(--color-attention), transparent 85%);
    border-radius: calc(var(--border-radius) / 2);
    color: var(--color-attention);
}

/* ==================== Value Displays ==================== */

.sa-value-group,
.dh-value-group {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    padding: var(--sa-padding-small, var(--dh-padding-small, 0.5rem)) var(--sa-padding-med, var(--dh-padding-med, 0.75rem));
    background: var(--sa-value-bg, var(--dh-value-bg, var(--color-mono-0)));
    border: 1px solid var(--sa-value-border, var(--dh-value-border, var(--theme-color-4)));
    border-radius: calc(var(--border-radius) / 2);
    font-family: var(--sa-font-mono, var(--dh-font-mono, var(--font-family-mono)));
    font-size: 0.95em;
}

.sa-var,
.dh-var {
    font-weight: 700;
    color: var(--sa-value-var, var(--dh-value-var, var(--theme-color-6)));
    font-style: italic;
}

.sa-value,
.dh-value {
    font-weight: 600;
    color: var(--sa-value-value, var(--dh-value-value, var(--color-text)));
    word-break: break-all;
}

/* ==================== Show/Hide Utilities ==================== */

.sa-received,
.sa-result,
.dh-received,
.dh-result {
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: all 400ms ease;
}

.sa-received.sa-show,
.sa-result.sa-show,
.dh-received.dh-show,
.dh-result.dh-show {
    opacity: 1;
    max-height: 500px;
}

.sa-highlight,
.dh-highlight {
    animation: exchangeHighlight 1.2s ease-in-out !important;
}

/* ==================== Footer & Controls ==================== */

.sa-footer,
.dh-footer {
    display: flex;
    flex-direction: column;
    border-top: 2px solid var(--sa-border, var(--dh-border, var(--color-mono-4)));
    background: var(--sa-card-bg, var(--dh-card-bg, var(--color-mono-1)));

    @container (min-width: 1024px) {
        flex-direction: row;
        align-items: center;
    }
}

.sa-status,
.dh-status {
    min-height: 2.5em;
    padding: var(--sa-padding, var(--dh-padding, 1rem));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9em;
    color: var(--sa-text-secondary, var(--dh-text-secondary, var(--color-mono-6)));
    line-height: 1.5;

    @container (min-width: 1024px) {
        flex: 1;
        border-right: 2px solid var(--sa-border, var(--dh-border, var(--color-mono-4)));
    }

    &:empty {
        display: none;
    }
}

.sa-status-info,
.dh-status-info {
    color: var(--color-text);
}

.sa-status-success,
.dh-status-success {
    color: var(--color-good);
    font-weight: 600;
}

.sa-status-warning,
.dh-status-warning {
    color: var(--highlight-color, var(--color-attention));
}

.sa-controls,
.dh-controls {
    display: flex;
    gap: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
    padding: var(--sa-padding, var(--dh-padding, 1rem));
    flex-wrap: wrap;

    @container (max-width: 480px) {
        flex-direction: column;
    }
}

.sa-btn,
.dh-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sa-gap-small, var(--dh-gap-small, 0.5rem));
    padding: var(--sa-padding-small, var(--dh-padding-small, 0.5rem)) var(--sa-padding, var(--dh-padding, 1rem));
    background: var(--sa-btn-bg, var(--dh-btn-bg, var(--color-mono-min)));
    border: 1px solid var(--sa-btn-border, var(--dh-btn-border, var(--color-mono-3)));
    border-radius: calc(var(--border-radius) / 2);
    color: var(--sa-btn-text, var(--dh-btn-text, var(--color-text)));
    font-family: inherit;
    font-size: 1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;

    @container (min-width: 481px) {
        width: auto;
    }

    &:hover:not(:disabled) {
        background: var(--color-mono-1);
        border-color: var(--sa-btn-hover, var(--dh-btn-hover, var(--theme-color)));
        transform: translateY(-1px);
        box-shadow: var(--box-shadow-small);
    }

    &:active:not(:disabled) {
        transform: translateY(0);
    }

    &:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
}

.sa-btn-reset:hover:not(:disabled),
.dh-btn-reset:hover:not(:disabled) {
    border-color: var(--sa-btn-reset-color, var(--dh-btn-reset-color, var(--color-attention)));
    color: var(--sa-btn-reset-color, var(--dh-btn-reset-color, var(--color-attention)));
}

/* ==================== Error States ==================== */

.sa-error,
.dh-error {
    padding: 2em;
    text-align: center;
    color: var(--error-color);
    font-weight: 600;
    background: color-mix(in srgb, var(--error-color), transparent 90%);
    border: 2px solid var(--error-color);
    border-radius: var(--border-radius);
}

/* ==================== Animations ==================== */

@keyframes exchangeArrowPulse {
    0%, 100% { transform: scale(1.00); }
    50%      { transform: scale(1.05); }
}

@keyframes exchangeHighlight {
    0%, 100% {
        transform: scale(1.00);
        filter: brightness(1.0);
    }
    50% {
        transform: scale(1.05);
        filter: brightness(1.2);
    }
}

@keyframes exchangeEveHighlight {
    0%, 100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 transparent;
    }
    50% {
        transform: scale(1.02);
        box-shadow: 0 0 0 4px var(--sa-eve-border, var(--dh-eve-border, var(--color-attention)));
    }
}

@keyframes exchangeFadeIn {
    from {
        opacity: 0;
        transform: translateY(-4px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
